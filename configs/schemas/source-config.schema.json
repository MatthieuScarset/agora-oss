{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Agora OSS Source Configuration Schema v1",
    "description": "Schema for defining a data source in Agora OSS",
    "type": "object",
    "required": [
        "name",
        "source_family",
        "connector",
        "endpoints"
    ],
    "properties": {
        "name": {
            "type": "string",
            "description": "Human-readable name for this source instance",
            "examples": [
                "drupal.org community",
                "wordpress.org plugins"
            ]
        },
        "source_family": {
            "type": "string",
            "description": "Ecosystem or platform family",
            "enum": [
                "drupalorg",
                "wordpressorg",
                "github",
                "gitlab",
                "custom"
            ]
        },
        "connector": {
            "type": "object",
            "description": "Plugin/connector configuration",
            "required": [
                "plugin_name",
                "plugin_version"
            ],
            "properties": {
                "plugin_name": {
                    "type": "string",
                    "description": "Name of the plugin module"
                },
                "plugin_version": {
                    "type": "string",
                    "description": "Version of the plugin (semver)",
                    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+.*$"
                },
                "capabilities": {
                    "type": "array",
                    "description": "Requested capabilities",
                    "items": {
                        "type": "string",
                        "enum": [
                            "discover_capabilities",
                            "fetch_full",
                            "fetch_incremental",
                            "emit_raw_envelope",
                            "map_to_canonical",
                            "report_health"
                        ]
                    }
                }
            }
        },
        "endpoints": {
            "type": "array",
            "description": "API endpoints or data source URIs",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "url",
                    "entity_type"
                ],
                "properties": {
                    "url": {
                        "type": "string",
                        "description": "API endpoint or data URI"
                    },
                    "entity_type": {
                        "type": "string",
                        "enum": [
                            "actor",
                            "project",
                            "issue",
                            "event",
                            "contribution"
                        ]
                    },
                    "method": {
                        "type": "string",
                        "enum": [
                            "GET",
                            "POST"
                        ],
                        "default": "GET"
                    },
                    "pagination": {
                        "type": "object",
                        "description": "Pagination strategy",
                        "properties": {
                            "strategy": {
                                "type": "string",
                                "enum": [
                                    "offset",
                                    "cursor",
                                    "page",
                                    "none"
                                ]
                            },
                            "page_size": {
                                "type": "integer",
                                "minimum": 1,
                                "maximum": 10000
                            }
                        }
                    },
                    "rate_limit": {
                        "type": "object",
                        "properties": {
                            "requests_per_second": {
                                "type": "number"
                            },
                            "burst_size": {
                                "type": "integer"
                            }
                        }
                    }
                }
            }
        },
        "authentication": {
            "type": "object",
            "description": "Authentication credentials (stored in secrets, not in config)",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "none",
                        "api_key",
                        "oauth2",
                        "basic",
                        "custom"
                    ]
                },
                "credentials_ref": {
                    "type": "string",
                    "description": "Reference to secrets store (e.g., 'env:DRUPAL_API_KEY')"
                }
            }
        },
        "refresh_policy": {
            "type": "object",
            "description": "Schedule and strategy for data refresh",
            "properties": {
                "interval": {
                    "type": "string",
                    "description": "Cron expression or duration (e.g., '0 */6 * * *' or 'PT6H')"
                },
                "strategy": {
                    "type": "string",
                    "enum": [
                        "full",
                        "incremental",
                        "adaptive"
                    ],
                    "description": "full: re-fetch all data; incremental: fetch only changes; adaptive: choose based on source"
                },
                "timeout_seconds": {
                    "type": "integer",
                    "minimum": 1,
                    "default": 3600
                }
            }
        },
        "quality_policy": {
            "type": "string",
            "description": "Reference to quality policy file (e.g., 'quality-policy.yaml')"
        },
        "mapping_pack": {
            "type": "string",
            "description": "Reference to mapping rules file (e.g., 'drupalorg/default.mapping.yaml')"
        },
        "locales": {
            "type": "array",
            "description": "Supported locales for this source",
            "items": {
                "type": "string",
                "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
            },
            "examples": [
                "en",
                "es",
                "fr",
                "de"
            ]
        },
        "primary_locale": {
            "type": "string",
            "description": "Default locale if not specified",
            "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
            "default": "en"
        },
        "metadata": {
            "type": "object",
            "description": "Additional metadata",
            "properties": {
                "ecosystem": {
                    "type": "string"
                },
                "maintainer": {
                    "type": "string"
                },
                "contact": {
                    "type": "string",
                    "format": "email"
                },
                "tags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Whether this source is active"
        }
    }
}