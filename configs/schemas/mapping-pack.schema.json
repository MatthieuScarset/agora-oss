{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Agora OSS Mapping Pack Schema v1",
    "description": "Schema for defining source-to-canonical entity mappings",
    "type": "object",
    "required": [
        "version",
        "source_family",
        "entity_mappings"
    ],
    "properties": {
        "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+.*$",
            "description": "Semantic version of this mapping pack"
        },
        "source_family": {
            "type": "string",
            "description": "Which source family this mapping targets"
        },
        "description": {
            "type": "string",
            "description": "Human-readable description of this mapping"
        },
        "entity_mappings": {
            "type": "object",
            "description": "Mapping rules for each entity type",
            "properties": {
                "actor": {
                    "$ref": "#/definitions/entity_mapping"
                },
                "project": {
                    "$ref": "#/definitions/entity_mapping"
                },
                "issue": {
                    "$ref": "#/definitions/entity_mapping"
                },
                "event": {
                    "$ref": "#/definitions/entity_mapping"
                },
                "contribution": {
                    "$ref": "#/definitions/entity_mapping"
                }
            }
        },
        "id_strategy": {
            "type": "object",
            "description": "How to compute canonical_id from source data",
            "properties": {
                "actor": {
                    "type": "string",
                    "description": "Expression to compute actor ID (e.g., 'user.uid')"
                },
                "project": {
                    "type": "string",
                    "description": "Expression to compute project ID"
                },
                "issue": {
                    "type": "string",
                    "description": "Expression to compute issue ID"
                }
            }
        },
        "stitching_rules": {
            "type": "array",
            "description": "Rules for identity stitching",
            "items": {
                "type": "object",
                "required": [
                    "name",
                    "entity_type",
                    "match_fields"
                ],
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "entity_type": {
                        "type": "string",
                        "enum": [
                            "actor",
                            "project",
                            "issue"
                        ]
                    },
                    "match_fields": {
                        "type": "array",
                        "description": "Fields to match for identity stitching",
                        "items": {
                            "type": "string"
                        }
                    },
                    "confidence": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1,
                        "description": "Confidence score for this stitching rule"
                    },
                    "cross_source": {
                        "type": "boolean",
                        "description": "Whether to allow cross-source stitching"
                    }
                }
            }
        },
        "field_transformations": {
            "type": "object",
            "description": "Custom transformations for specific fields",
            "additionalProperties": {
                "type": "object",
                "properties": {
                    "expression": {
                        "type": "string",
                        "description": "Transformation expression (e.g., 'lower(trim(name))')"
                    },
                    "default": {
                        "description": "Default value if source field is missing"
                    },
                    "required": {
                        "type": "boolean"
                    }
                }
            }
        },
        "constants": {
            "type": "object",
            "description": "Constant values to inject into entities"
        }
    },
    "definitions": {
        "entity_mapping": {
            "type": "object",
            "description": "Mapping configuration for a single entity type",
            "properties": {
                "source_entity_name": {
                    "type": "string",
                    "description": "Name of the entity type in the source system"
                },
                "field_map": {
                    "type": "object",
                    "description": "Mapping of source fields to canonical fields",
                    "additionalProperties": {
                        "type": [
                            "string",
                            "object"
                        ],
                        "description": "Source field path or object with transformation"
                    }
                },
                "identity": {
                    "type": "object",
                    "description": "How to compute the canonical ID",
                    "properties": {
                        "fields": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "template": {
                            "type": "string",
                            "description": "Template for ID generation (e.g., '{type}:{family}:{source}:{id}')"
                        }
                    }
                },
                "relationships": {
                    "type": "array",
                    "description": "Relationships to extract",
                    "items": {
                        "type": "object",
                        "required": [
                            "relation_type",
                            "target_entity",
                            "source_field"
                        ],
                        "properties": {
                            "relation_type": {
                                "type": "string"
                            },
                            "target_entity": {
                                "type": "string"
                            },
                            "source_field": {
                                "type": "string"
                            },
                            "confidence": {
                                "type": "number",
                                "minimum": 0,
                                "maximum": 1
                            }
                        }
                    }
                },
                "conditional_mappings": {
                    "type": "array",
                    "description": "Conditional field mappings based on source data",
                    "items": {
                        "type": "object",
                        "required": [
                            "condition",
                            "field_map"
                        ],
                        "properties": {
                            "condition": {
                                "type": "string",
                                "description": "Expression to evaluate (e.g., 'status == \"published\"')"
                            },
                            "field_map": {
                                "type": "object"
                            }
                        }
                    }
                }
            }
        }
    }
}