# Core
COMPOSE_PROJECT_NAME=agora
TZ=UTC

# PostgreSQL (+ pgvector)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agora
POSTGRES_USER=agora
POSTGRES_PASSWORD=agora_local_password

# Main app database URL (sync clients)
DATABASE_URL=postgresql://agora:agora_local_password@postgres:5432/agora

# Vector store strategy
VECTOR_STORE_BACKEND=pgvector
VECTOR_STORE_TABLE=document_embeddings

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# MinIO (S3-compatible local storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=agora-raw
S3_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_USE_SSL=false
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1

# Prefect
PREFECT_API_PORT=4200
PREFECT_API_URL=http://localhost:4200/api
PREFECT_API_URL_INTERNAL=http://prefect-server:4200/api
PREFECT_UI_URL=http://localhost:4200
PREFECT_WORK_POOL=agora-local-pool
PREFECT_LOG_LEVEL=INFO
PREFECT_SERVER_DATABASE_CONNECTION_URL=postgresql+asyncpg://agora:agora_local_password@postgres:5432/agora

# Frontend (Node.js dev service)
NODE_ENV=development
FRONTEND_PORT=3000
